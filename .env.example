# LLM API config (supports any LLM API compatible with the OpenAI SDK format)
# Recommended: Alibaba Bailian qwen-plus model — https://bailian.console.aliyun.com/
# Note: token consumption can be high — start with fewer than 40 rounds

# Auth mode: "api_key" (default) or "codex" (uses ChatGPT subscription via OAuth)
# For codex mode, run: python -m backend.scripts.codex_login
LLM_AUTH_MODE=api_key
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Memory Graph Config =====
# The free monthly quota is sufficient for basic use — https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Config (Optional) =====
# If not using a boost LLM, remove these variables from your .env file entirely
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here